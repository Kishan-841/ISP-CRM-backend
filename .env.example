# PostgreSQL (used by docker-compose)
POSTGRES_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=production

# CORS - Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=https://isp-crm-frontend.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
