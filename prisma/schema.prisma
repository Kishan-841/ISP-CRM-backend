// Plan Upgrade/Downgrade History - tracks all plan changes for billing and audit
model PlanUpgradeHistory {
  id                    String   @id @default(uuid())
  leadId                String

  // Action type (UPGRADE or DOWNGRADE)
  actionType            String   @default("UPGRADE") // UPGRADE or DOWNGRADE

  // Previous plan details (snapshot at time of change)
  previousPlanName      String
  previousBandwidth     Int
  previousUploadBandwidth Int?
  previousArc           Float
  previousValidityDays  Int
  previousBillingType   String
  previousPlanStartDate DateTime
  previousPlanEndDate   DateTime

  // New plan details
  newPlanName           String
  newBandwidth          Int
  newUploadBandwidth    Int?
  newArc                Float     // New total ARC (old +/- change)
  additionalArc         Float?    // Additional ARC added during upgrade
  degradeArc            Float?    // ARC subtracted during downgrade

  // Change timing
  upgradeDate           DateTime    // Date change takes effect

  // Pro-rated billing calculation
  daysOnOldPlan         Int         // Days from plan start to change date
  daysOnNewPlan         Int         // Days from change date to billing period end
  oldPlanAmount         Float       // Pro-rated amount for old plan period
  newPlanAmount         Float       // Pro-rated amount for new plan period
  totalAmount           Float       // Combined amount for billing period
  originalAmount        Float       // What it would have been without change
  differenceAmount      Float       // Additional/credit amount due to change

  // For downgrades - link to credit note
  creditNoteId          String?     // Credit note created for downgrade

  // Metadata
  notes                 String?
  createdById           String
  createdAt             DateTime    @default(now())

  // Relations
  lead                  Lead        @relation("PlanUpgrades", fields: [leadId], references: [id], onDelete: Cascade)
  createdBy             User        @relation("PlanUpgradesCreated", fields: [createdById], references: [id])

  @@index([leadId])
  @@index([createdAt])
  @@index([upgradeDate])
  @@index([actionType])
}

model VendorPurchaseOrder {
  id                    String           @id @default(uuid())
  poNumber              String           @unique
  poDate                DateTime         @default(now())
  validityMonths        Int
  vendorCategory        VendorCategory

  // Linked entities
  vendorId              String
  leadId                String

  // Denormalized lead details for display
  customerName          String
  popLocation           String?
  installationLocation  String?

  // Fiber-specific fields
  distance              Float?
  rate                  Float?

  // Commission/Channel Partner specific fields
  commissionPercentage  Float?
  arcAmount             Float?
  bandwidthSpeed        String?

  // Third Party specific fields
  paymentTerms          String?
  lockInPeriod          Int?
  noticePeriod          Int?

  // Amount calculation
  baseAmount            Float
  gstApplicable         Boolean          @default(false)
  gstPercentage         Float?
  gstAmount             Float?
  totalAmount           Float

  termsAndConditions    String?

  // Approval
  status                VendorPOStatus   @default(PENDING_APPROVAL)
  approvedById          String?
  approvedAt            DateTime?
  rejectedById          String?
  rejectedAt            DateTime?
  rejectionReason       String?

  // Email tracking
  emailSentAt           DateTime?
  emailSentTo           String?

  // Audit
  createdById           String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Relations
  vendor                Vendor           @relation("VendorPOs", fields: [vendorId], references: [id])
  lead                  Lead             @relation("LeadVendorPOs", fields: [leadId], references: [id])
  createdBy             User             @relation("VendorPOsCreated", fields: [createdById], references: [id])
  approvedBy            User?            @relation("VendorPOsApproved", fields: [approvedById], references: [id])
  rejectedBy            User?            @relation("VendorPOsRejected", fields: [rejectedById], references: [id])

  @@index([poNumber])
  @@index([vendorId])
  @@index([leadId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

