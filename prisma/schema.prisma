  contactName       String
  phone             String
  email             String?
  address           String?
  city              String?
  state             String?
  requirements      String?
  status            CustomerEnquiryStatus @default(SUBMITTED)
  createdLeadId     String?               @unique
  createdLead       Lead?                 @relation("EnquiryCreatedFrom", fields: [createdLeadId], references: [id], onDelete: SetNull)
