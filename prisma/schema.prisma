// Document sequence counter for generating unique document numbers
// Format: PREFIX/DD/MM/YY-XXXX (e.g., GLL/27/01/26-0001)
// Counter never resets - global per document type
model DocumentSequence {
  id            String   @id @default(uuid())
  documentType  String   @unique  // INVOICE, RECEIPT, CREDIT_NOTE
  prefix        String             // GLL, RCP, CN
  lastNumber    Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@index([documentType])
}

// Collection Call Log - tracks collection calls made by accounts team
model CollectionCallLog {
