generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                 String                @id @default(uuid())
  email                              String                @unique
  password                           String
  name                               String
  mobile                             String?
  role                               Role                  @default(ISR)
  isActive                           Boolean               @default(true)
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @updatedAt
  callLogs                           CallLog[]
  collectionCalls                    CollectionCallLog[]   @relation("CollectionCallsMade")
  assignedCampaigns                  CampaignAssignment[]
  createdCampaignData                CampaignData[]        @relation("CampaignDataCreatedBy")
  deliveryRequestsAreaHeadApproved   DeliveryRequest[]     @relation("DeliveryRequestAreaHeadApproved")
  deliveryRequestsAreaHeadRejected   DeliveryRequest[]     @relation("DeliveryRequestAreaHeadRejected")
  deliveryRequestsAssignedToStore    DeliveryRequest[]     @relation("DeliveryRequestAssignedToStore")
  deliveryRequestsPushedToNoc        DeliveryRequest[]     @relation("DeliveryRequestPushedToNoc")
  deliveryRequestsCreated            DeliveryRequest[]     @relation("DeliveryRequestCreatedBy")
  deliveryRequestsSuperAdminApproved DeliveryRequest[]     @relation("DeliveryRequestSuperAdminApproved")
  deliveryRequestsSuperAdminRejected DeliveryRequest[]     @relation("DeliveryRequestSuperAdminRejected")
  deliveryRequestLogsPerformed       DeliveryRequestLog[]  @relation("DeliveryRequestLogPerformedBy")
  uploadLinksCreated                 DocumentUploadLink[]  @relation("UploadLinksCreated")
  emailsSent                         EmailLog[]            @relation("EmailsSent")
  inventoryCreated                   InventoryItem[]       @relation("InventoryCreatedBy")
  invoicesCreated                    Invoice[]             @relation("InvoicesCreatedBy")
  paymentsCreated                    InvoicePayment[]      @relation("PaymentsCreatedBy")
  advancePaymentsCreated             AdvancePayment[]      @relation("AdvancePaymentsCreatedBy")
  creditNotesCreated                 CreditNote[]          @relation("CreditNotesCreatedBy")
  ledgerEntriesCreated               LedgerEntry[]         @relation("LedgerEntriesCreatedBy")
  accountsVerifiedLeads              Lead[]                @relation("AccountsVerifiedBy")
  gstVerifiedLeads                   Lead[]                @relation("GstVerifiedBy")
  actualPlanCreatedLeads             Lead[]                @relation("ActualPlanCreatedBy")
  assignedLeads                      Lead[]                @relation("AssignedTo")
  createdLeads                       Lead[]                @relation("CreatedBy")
  customerAcceptanceLeads            Lead[]                @relation("CustomerAcceptanceBy")
  customerAccountsCreated            Lead[]                @relation("CustomerCreatedBy")
  deliveryAssignedLeads              Lead[]                @relation("DeliveryAssignedTo")
  demoPlanAssignedLeads              Lead[]                @relation("DemoPlanAssignedBy")
  feasibilityAssignedLeads           Lead[]                @relation("FeasibilityAssignedTo")
  nocAssignedLeads                   Lead[]                @relation("NocAssignedTo")
  nocConfiguredLeads                 Lead[]                @relation("NocConfiguredBy")
  nocPushedToDeliveryLeads           Lead[]                @relation("NocPushedToDelivery")
  opsApprovedLeads                   Lead[]                @relation("OpsApprovedBy")
  superAdmin2ApprovedLeads           Lead[]                @relation("SuperAdmin2ApprovedBy")
  pushedToInstallation               Lead[]                @relation("PushedToInstallation")
  speedTestUploadedLeads             Lead[]                @relation("SpeedTestUploadedBy")
  notifications                      Notification[]
  receiptBatchesVerified             ReceiptBatchLog[]     @relation("ReceiptBatchVerifiedBy")
  storeProductsCreated               StoreProduct[]        @relation("StoreProductCreatedBy")
  storePOsAdminApproved              StorePurchaseOrder[]  @relation("StorePOAdminApproved")
  storePurchaseOrders                StorePurchaseOrder[]  @relation("StorePOCreatedBy")
  storePOsReceiptVerified            StorePurchaseOrder[]  @relation("StorePOReceiptVerified")
  storePOsRejected                   StorePurchaseOrder[]  @relation("StorePORejected")
  storePOsSuperAdminApproved         StorePurchaseOrder[]  @relation("StorePOSuperAdminApproved")
  storeSerialAdded                   StoreSerialItem[]     @relation("StoreSerialAddedBy")
  storeStockAdded                    StoreStock[]          @relation("StoreStockAddedBy")
  storeIntakesPerformed              StoreStockIntakeLog[] @relation("StoreIntakePerformedBy")
  vendorsCreated                     Vendor[]              @relation("VendorsCreated")
  vendorsAdminApproved               Vendor[]              @relation("VendorAdminApproved")
  vendorsAccountsApproved            Vendor[]              @relation("VendorAccountsApproved")
  // SAM relations
  samAssignmentsAsExecutive          SAMAssignment[]       @relation("SAMExecutiveAssignments")
  samAssignmentsCreated              SAMAssignment[]       @relation("SAMAssignedBy")
  samAssignmentHistoryAsExecutive    SAMAssignmentHistory[] @relation("SAMAssignmentHistoryExecutive")
  samAssignmentHistoryAsAssigner     SAMAssignmentHistory[] @relation("SAMAssignmentHistoryAssignedBy")
  samMeetings                        SAMMeeting[]          @relation("SAMExecutiveMeetings")
  samVisits                          SAMVisit[]            @relation("SAMExecutiveVisits")
  samCommunications                  CustomerCommunication[] @relation("SAMCommunications")
  // Plan upgrade history
  planUpgradesCreated                PlanUpgradeHistory[]  @relation("PlanUpgradesCreated")
  // Vendor docs verified
  vendorDocsVerifiedLeads            Lead[]                @relation("VendorDocsVerifiedBy")
  // Vendor PO relations
  vendorPOsCreated                   VendorPurchaseOrder[] @relation("VendorPOsCreated")
  vendorPOsApproved                  VendorPurchaseOrder[] @relation("VendorPOsApproved")
  vendorPOsRejected                  VendorPurchaseOrder[] @relation("VendorPOsRejected")
  // Status change audit trail
  statusChangeLogs                   StatusChangeLog[]     @relation("StatusChangeLogs")
  // Complaint relations
  complaintsCreated                  Complaint[]           @relation("ComplaintsCreatedBy")
  complaintAssignments               ComplaintAssignment[] @relation("ComplaintAssignments")
  complaintAssignedBy                ComplaintAssignment[] @relation("ComplaintAssignedBy")
  complaintAttachmentsUploaded         ComplaintAttachment[] @relation("ComplaintAttachmentUploadedBy")
  complaintsClosed                     Complaint[]           @relation("ComplaintsClosedBy")
  // BDM-ISR binding
  campaignDataAssignedByBdm          CampaignData[]        @relation("CampaignDataAssignedByBdm")
  campaignDataLastEditedBy           CampaignData[]        @relation("CampaignDataLastEditedBy")
  // Campaigns created
  campaignsCreated                   Campaign[]            @relation("CampaignCreatedBy")
  // Service Order relations
  serviceOrdersCreated               ServiceOrder[]        @relation("ServiceOrdersCreated")
  serviceOrdersApproved              ServiceOrder[]        @relation("ServiceOrdersApproved")
  serviceOrdersProcessed             ServiceOrder[]        @relation("ServiceOrdersProcessed")
  serviceOrderDocsReviewed           ServiceOrder[]        @relation("ServiceOrderDocsReviewed")
  serviceOrderNocProcessed           ServiceOrder[]        @relation("ServiceOrderNocProcessed")
  serviceOrderActivationSet          ServiceOrder[]        @relation("ServiceOrderActivationSet")
  // Team leader hierarchy
  teamLeaderId                       String?
  teamLeader                         User?                 @relation("TeamMemberRelation", fields: [teamLeaderId], references: [id], onDelete: SetNull)
  teamMembers                        User[]                @relation("TeamMemberRelation")
  popLocationsCreated                PopLocation[]         @relation("PopLocationCreatedBy")

  @@index([teamLeaderId])
}

model Campaign {
  id           String               @id @default(uuid())
  name         String
  description  String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  code         String               @unique
  dataSource   String?
  status       CampaignStatus       @default(ACTIVE)
  type         CampaignType         @default(ALL)
  rejectedRecords Int               @default(0)
  createdById             String?
  channelPartnerVendorId  String?
  createdBy    User?                @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  channelPartnerVendor Vendor?      @relation("CampaignChannelPartner", fields: [channelPartnerVendorId], references: [id])
  assignments  CampaignAssignment[]
  campaignData CampaignData[]

  @@index([type])
  @@index([createdById])
  @@index([type, createdById])
  @@index([channelPartnerVendorId])
}

model CampaignAssignment {
  id         String   @id @default(uuid())
  userId     String
  campaignId String
  assignedAt DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

model CampaignData {
  id              String     @id @default(uuid())
  campaignId      String
  name            String
  phone           String
  email           String?
  address         String?
  status          DataStatus @default(NEW)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  assignedToId    String?
  callLaterAt     DateTime?
  otherReason     String?
  city            String?
  company         String
  firstName       String?
  industry        String?
  lastName        String?
  title           String
  companySize     String?
  createdById     String?
  isSelfGenerated Boolean    @default(false)
  linkedinUrl     String?
  source          String?
  state           String?
  whatsapp        String?
  callLogs        CallLog[]
  campaign        Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy       User?      @relation("CampaignDataCreatedBy", fields: [createdById], references: [id])
  assignedByBdmId String?
  assignedByBdm   User?      @relation("CampaignDataAssignedByBdm", fields: [assignedByBdmId], references: [id])
  lastEditedById          String?
  lastEditedBy            User?      @relation("CampaignDataLastEditedBy", fields: [lastEditedById], references: [id])
  lastEditedAt            DateTime?
  channelPartnerVendorId  String?
  channelPartnerVendor    Vendor?    @relation("CampaignDataChannelPartner", fields: [channelPartnerVendorId], references: [id])
  lead            Lead?

  @@index([campaignId, status])
  @@index([campaignId, assignedToId])
  @@index([assignedToId, status])
  @@index([campaignId, status, callLaterAt])
  @@index([assignedByBdmId])
  @@index([channelPartnerVendorId])
}

model CallLog {
  id             String       @id @default(uuid())
  campaignDataId String
  userId         String
  startTime      DateTime
  endTime        DateTime?
  duration       Int?
  status         DataStatus
  notes          String?
  otherReason    String?
  createdAt      DateTime     @default(now())
  campaignData   CampaignData @relation(fields: [campaignDataId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignDataId])
  @@index([userId])
  @@index([campaignDataId, userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Product {
  id               String                @id @default(uuid())
  title            String
  status           ProductStatus         @default(ACTIVE)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  parentId         String?
  code             String?
  isSerialized     Boolean               @default(false)
  leadProducts     LeadProduct[]
  parent           Product?              @relation("ProductHierarchy", fields: [parentId], references: [id])
  children         Product[]             @relation("ProductHierarchy")
  storeSerialItems StoreSerialItem[]
  storeStock       StoreStock[]
  intakeLogs       StoreStockIntakeLog[]
}

model Lead {
  id                        String               @id @default(uuid())
  leadNumber                String?              @unique
  campaignDataId            String               @unique
  requirements              String?
  status                    LeadStatus           @default(NEW)
  createdById               String
  assignedToId              String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  sharedVia                 String?
  type                      LeadType             @default(QUALIFIED)
  isImported                Boolean              @default(false)
  linkedinUrl               String?
  callLaterAt               DateTime?
  dropReason                String?
  location                  String?
  feasibilityAssignedToId   String?
  feasibilityNotes          String?
  feasibilityReviewedAt     DateTime?
  docsRejectedReason        String?
  docsVerifiedAt            DateTime?
  docsVerifiedById          String?
  documents                 Json?
  meetingDate               DateTime?
  meetingNotes              String?
  meetingOutcome            String?
  meetingPlace              String?
  latitude                  Float?
  longitude                 Float?
  bandwidthRequirement      String?
  fullAddress               String?
  meetingCount              Int                  @default(1)
  accountsNotes             String?
  accountsRejectedReason    String?
  accountsVerifiedAt        DateTime?
  accountsVerifiedById      String?
  accountsStatus            AccountsStatus?
  // GST Verification fields
  customerGstNo             String?           // GST Number entered by accounts team
  customerLegalName         String?           // Legal name as per GST certificate
  gstVerifiedAt             DateTime?         // When GST was verified
  gstVerifiedById           String?           // Who verified it

  // Additional Customer Details (Accounts Review)
  panCardNo                 String?           // PAN Card number
  tanNumber                 String?           // TAN number
  installationAddress       String?           // Installation address (100 char limit)
  installationPincode       String?           // Installation pincode
  poNumber                  String?           // Purchase Order number
  poExpiryDate              DateTime?         // PO expiry date
  billDate                  DateTime?         // Bill date
  technicalInchargeMobile   String?           // Technical incharge mobile
  technicalInchargeEmail    String?           // Technical incharge email
  accountsInchargeMobile    String?           // Accounts incharge mobile
  accountsInchargeEmail     String?           // Accounts incharge email
  bdmName                   String?           // BDM name
  serviceManager            String?           // Service manager name
  advanceAmount             Float?
  arcAmount                 Float?
  originalArcAmount         Float?
  otcAmount                 Float?
  quotationAttachments      Json?
  otcInvoiceId              String?              @unique
  otcInvoiceGeneratedAt     DateTime?
  paymentTerms              String?
  interestLevel             InterestLevel?
  installationNotes         String?
  pushedToInstallationAt    DateTime?
  pushedToInstallationById  String?
  verificationAttempts      Int                  @default(0)
  opsApprovalStatus         OpsApprovalStatus?
  opsApprovedAt             DateTime?
  opsApprovedById           String?
  opsRejectedReason         String?
  superAdmin2ApprovalStatus SuperAdmin2ApprovalStatus?
  superAdmin2ApprovedAt     DateTime?
  superAdmin2ApprovedById   String?
  superAdmin2RejectedReason String?
  loginCompletedAt          DateTime?
  loginCompletedById        String?
  docUploadMethod           String?
  tentativePrice            Float?
  deliveryAssignedAt        DateTime?
  deliveryAssignedToId      String?
  deliveryNotes             String?
  deliveryProducts          Json?
  deliveryStatus            String?
  deliveryCompletedViewedAt DateTime?
  fromAddress               String?
  fromLatitude              Float?
  fromLongitude             Float?
  numberOfIPs               Int?
  customerCreatedAt         DateTime?
  customerCreatedById       String?
  customerIpAssigned        String?
  customerPassword          String?
  customerSwitchPort        String?
  customerUserId            String?              @unique
  customerUsername          String?              @unique
  nocAssignedToId           String?
  nocAssignedAt             DateTime?
  nocConfiguredAt           DateTime?
  nocConfiguredById         String?
  billingAddress            String?
  billingPincode            String?
  expectedDeliveryDate      DateTime?
  // Cold Lead flag: true when BDM parked a lead with partial details after
  // a lukewarm meeting. Cold leads live in the Lead Pipeline tab and are
  // excluded from the Opportunity Pipeline until the BDM completes them.
  isColdLead                Boolean              @default(false)
  // Simplified feasibility review fields (vendor setup moved to delivery)
  feasibilityVendorType     String?              // ownNetwork | fiberVendor | commissionVendor | thirdParty | telco
  tentativeCapex            Float?               // Feasibility team's CAPEX estimate (overwritten by delivery with actual)
  tentativeOpex             Float?               // Feasibility team's OPEX estimate (overwritten by delivery with actual)
  feasibilityDescription    String?              // Free-text notes from FT review
  deliveryVendorSetupDone   Boolean              @default(false) // Must be true before material request
  circuitId                 String?              @unique
  customerIpAddresses       Json?
  nocPushedToDeliveryAt     DateTime?
  nocPushedToDeliveryById   String?
  customerAcceptanceAt      DateTime?
  customerAcceptanceById    String?
  customerAcceptanceNotes   String?
  customerAcceptanceStatus  String?
  customerAcceptanceScreenshot String?
  installationCompletedAt   DateTime?
  installationStartedAt     DateTime?
  latencyTestScreenshot     String?
  speedTestScreenshot       String?
  speedTestUploadedAt       DateTime?
  speedTestUploadedById     String?
  demoPlanAssignedAt        DateTime?
  demoPlanAssignedById      String?
  demoPlanBandwidth         Int?
  demoPlanDataLimit         Int?
  demoPlanIsActive          Boolean              @default(false)
  demoPlanName              String?
  demoPlanNotes             String?
  demoPlanUploadBandwidth   Int?
  demoPlanValidityDays      Int?
  actualPlanBandwidth       Int?
  actualPlanCreatedAt       DateTime?
  actualPlanCreatedById     String?
  actualPlanDataLimit       Int?
  actualPlanEndDate         DateTime?
  actualPlanIsActive        Boolean              @default(false)
  actualPlanName            String?
  actualPlanNotes           String?
  actualPlanPrice           Float?
  actualPlanStartDate       DateTime?
  actualPlanUploadBandwidth Int?
  actualPlanValidityDays    Int?
  actualPlanBillingType     String?
  actualPlanBillingCycle    BillingCycle?         @default(MONTHLY)
  demoPlanBillingType       String?
  demoPlanEndDate           DateTime?
  demoPlanStartDate         DateTime?
  demoPlanPrice             Float?
  deliveryRequests          DeliveryRequest[]    @relation("DeliveryRequestLead")
  uploadLinks               DocumentUploadLink[]
  invoices                  Invoice[]            @relation("LeadInvoices")
  ledgerEntries             LedgerEntry[]        @relation("CustomerLedger")
  advancePayments           AdvancePayment[]     @relation("AdvancePayments")
  accountsVerifiedBy        User?                @relation("AccountsVerifiedBy", fields: [accountsVerifiedById], references: [id], onDelete: SetNull)
  gstVerifiedBy             User?                @relation("GstVerifiedBy", fields: [gstVerifiedById], references: [id], onDelete: SetNull)
  actualPlanCreatedBy       User?                @relation("ActualPlanCreatedBy", fields: [actualPlanCreatedById], references: [id], onDelete: SetNull)
  assignedTo                User?                @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  campaignData              CampaignData         @relation(fields: [campaignDataId], references: [id], onDelete: Cascade)
  createdBy                 User                 @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  customerAcceptanceBy      User?                @relation("CustomerAcceptanceBy", fields: [customerAcceptanceById], references: [id], onDelete: SetNull)
  customerCreatedBy         User?                @relation("CustomerCreatedBy", fields: [customerCreatedById], references: [id], onDelete: SetNull)
  deliveryAssignedTo        User?                @relation("DeliveryAssignedTo", fields: [deliveryAssignedToId], references: [id], onDelete: SetNull)
  demoPlanAssignedBy        User?                @relation("DemoPlanAssignedBy", fields: [demoPlanAssignedById], references: [id], onDelete: SetNull)
  feasibilityAssignedTo     User?                @relation("FeasibilityAssignedTo", fields: [feasibilityAssignedToId], references: [id], onDelete: SetNull)
  nocAssignedTo             User?                @relation("NocAssignedTo", fields: [nocAssignedToId], references: [id], onDelete: SetNull)
  nocConfiguredBy           User?                @relation("NocConfiguredBy", fields: [nocConfiguredById], references: [id], onDelete: SetNull)
  nocPushedToDeliveryBy     User?                @relation("NocPushedToDelivery", fields: [nocPushedToDeliveryById], references: [id], onDelete: SetNull)
  opsApprovedBy             User?                @relation("OpsApprovedBy", fields: [opsApprovedById], references: [id], onDelete: SetNull)
  superAdmin2ApprovedBy     User?                @relation("SuperAdmin2ApprovedBy", fields: [superAdmin2ApprovedById], references: [id], onDelete: SetNull)
  pushedToInstallationBy    User?                @relation("PushedToInstallation", fields: [pushedToInstallationById], references: [id], onDelete: SetNull)
  speedTestUploadedBy       User?                @relation("SpeedTestUploadedBy", fields: [speedTestUploadedById], references: [id], onDelete: SetNull)
  products                  LeadProduct[]
  moms                      MOM[]

  // SAM Customer Data Fields
  serviceType               ServiceType?         // ILL, P2P, MPLS, etc.
  ipDetails                 Json?                // IP allocation details { wan: "", lan: [], gateway: "", subnet: "" }
  cpeDetails                Json?                // CPE details { make: "", model: "", serialNo: "", macAddress: "" }
  contractStartDate         DateTime?            // Contract start date
  contractDurationMonths    Int?                 // Contract duration in months
  contractEndDate           DateTime?            // Contract end date (calculated)
  escalationMatrix          Json?                // Array of escalation contacts [{ level: 1, name: "", phone: "", email: "", designation: "" }]

  // SAM relations
  samAssignment             SAMAssignment?       @relation("SAMCustomer")
  samAssignmentHistory      SAMAssignmentHistory[] @relation("SAMAssignmentHistoryCustomer")
  samMeetings               SAMMeeting[]         @relation("SAMCustomerMeetings")
  samVisits                 SAMVisit[]           @relation("SAMCustomerVisits")
  customerCommunications    CustomerCommunication[] @relation("CustomerCommunications")
  // Plan upgrade history
  planUpgrades              PlanUpgradeHistory[] @relation("PlanUpgrades")
  // Complaints
  complaints                Complaint[]
  customerComplaintRequests CustomerComplaintRequest[]
  // Customer Enquiries (referrals)
  customerEnquiries         CustomerEnquiry[]           @relation("CustomerEnquiries")
  enquiryCreatedFrom        CustomerEnquiry?            @relation("EnquiryCreatedFrom")
  // Service Orders
  serviceOrders             ServiceOrder[]              @relation("ServiceOrderCustomer")

  // Vendor linkage
  vendorId                      String?
  vendorDocsVerifiedAt          DateTime?
  vendorDocsVerifiedById        String?
  vendorDocsRejectedReason      String?
  vendorCommissionPercentage    Float?            // Commission % set during feasibility review
  vendor                    Vendor?              @relation("LeadVendor", fields: [vendorId], references: [id])
  vendorDocsVerifiedBy      User?                @relation("VendorDocsVerifiedBy", fields: [vendorDocsVerifiedById], references: [id], onDelete: SetNull)
  vendorsCreatedFor         Vendor[]             @relation("VendorCreatedForLead")
  vendorPurchaseOrders      VendorPurchaseOrder[] @relation("LeadVendorPOs")

  @@index([vendorId])
  @@index([assignedToId, status])
  @@index([assignedToId, status, createdAt])
  @@index([assignedToId, status, callLaterAt])
  @@index([assignedToId, meetingDate])
  @@index([assignedToId, deliveryStatus])
  @@index([feasibilityAssignedToId, status])
  @@index([opsApprovalStatus, status])
  @@index([status, opsApprovalStatus, docsVerifiedAt])
  @@index([docsVerifiedAt, docsRejectedReason, accountsVerifiedAt])
  @@index([pushedToInstallationAt, deliveryStatus])
  @@index([pushedToInstallationAt, deliveryAssignedToId])
  @@index([customerUserId])
  @@index([customerUsername, actualPlanIsActive])
  @@index([customerUsername])
  @@index([status, createdAt])
  @@index([type, status])
  @@index([actualPlanIsActive, customerCreatedAt])
  @@index([customerGstNo])
  @@index([superAdmin2ApprovalStatus, status])
  @@index([isColdLead, assignedToId])
}

model LeadProduct {
  id        String   @id @default(uuid())
  leadId    String
  productId String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([leadId, productId])
}

model MOM {
  id           String    @id @default(uuid())
  leadId       String
  meetingDate  DateTime
  attendees    String?
  agenda       String?
  discussion   String
  nextSteps    String?
  followUpDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model EmailLog {
  id            String      @id @default(uuid())
  referenceId   String?
  referenceType String?
  to            String
  cc            String[]
  subject       String
  htmlSnapshot  String
  emailData     Json?
  attachments   Json?
  sentByUserId  String
  sentAt        DateTime    @default(now())
  status        EmailStatus @default(PENDING)
  errorMessage  String?
  resendId      String?
  sentBy        User        @relation("EmailsSent", fields: [sentByUserId], references: [id])

  @@index([referenceId])
  @@index([sentByUserId])
  @@index([sentAt])
}

model Vendor {
  id                    String               @id @default(uuid())
  companyName           String
  gstNumber             String?
  gstDocument           String?
  contactPerson         String?
  email                 String?
  phone                 String?
  panNumber             String?
  panDocument           String?
  address               String?
  city                  String?
  state                 String?
  isActive              Boolean              @default(true)
  // Bank details
  accountNumber         String?
  ifscCode              String?
  accountName           String?
  bankName              String?
  branchName            String?
  cancelledCheque       String?
  // Category & Approval
  category              VendorCategory?
  approvalStatus        VendorApprovalStatus @default(PENDING_ADMIN)
  adminApprovedById     String?
  adminApprovedAt       DateTime?
  adminRejectionReason  String?
  accountsApprovedById  String?
  accountsApprovedAt    DateTime?
  accountsRejectionReason String?
  rejectedAt            DateTime?
  // Vendor type & docs
  vendorType            VendorType?
  individualName        String?
  docsStatus            VendorDocsStatus     @default(PENDING)
  estimatedCapex        Float?
  estimatedOpex         Float?
  commissionPercentage  Float?
  createdForLeadId      String?
  // Base fields
  createdById           String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  // Relations
  storePurchaseOrders   StorePurchaseOrder[] @relation("StorePOVendor")
  vendorPurchaseOrders  VendorPurchaseOrder[] @relation("VendorPOs")
  createdBy             User                 @relation("VendorsCreated", fields: [createdById], references: [id])
  adminApprovedBy       User?                @relation("VendorAdminApproved", fields: [adminApprovedById], references: [id])
  accountsApprovedBy    User?                @relation("VendorAccountsApproved", fields: [accountsApprovedById], references: [id])
  createdForLead        Lead?                @relation("VendorCreatedForLead", fields: [createdForLeadId], references: [id])
  leads                 Lead[]               @relation("LeadVendor")
  campaignsAsCP         Campaign[]           @relation("CampaignChannelPartner")
  campaignDataAsCP      CampaignData[]       @relation("CampaignDataChannelPartner")

  @@index([companyName])
