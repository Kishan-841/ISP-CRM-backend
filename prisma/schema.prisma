// Status Change Audit Trail - tracks all status transitions across entities
model StatusChangeLog {
  id          String   @id @default(uuid())
  entityType  String   // "LEAD", "INVOICE", "DELIVERY_REQUEST", "VENDOR"
  entityId    String
  field       String   // "status", "opsApprovalStatus", "feasibilityStatus"
  oldValue    String?
  newValue    String
  changedById String?
  changedAt   DateTime @default(now())
  reason      String?

  changedBy   User?    @relation("StatusChangeLogs", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([changedById])
  @@index([changedAt])

  @@map("status_change_logs")
}

