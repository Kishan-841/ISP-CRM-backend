enum ServiceOrderType {
  UPGRADE
  DOWNGRADE
  RATE_REVISION
  DISCONNECTION
}

enum ServiceOrderStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PENDING_DOCS_REVIEW
  DOCS_REJECTED
  PENDING_NOC
  PENDING_SAM_ACTIVATION
  PENDING_ACCOUNTS
  COMPLETED
  CANCELLED
}

model ServiceOrder {
  id                    String               @id @default(uuid())
  orderNumber           String               @unique
  customerId            String
  orderType             ServiceOrderType
  status                ServiceOrderStatus   @default(PENDING_DOCS_REVIEW)
  createdById           String

  // Current plan snapshot (captured at creation)
  currentPlanName       String?
  currentBandwidth      Int?
  currentArc            Float?

  // New plan details (UPGRADE/DOWNGRADE only)
  newBandwidth          Int?
  newArc                Float?

  // Effective date (when the change should take effect)
  effectiveDate         DateTime?

  // Disconnection fields
  disconnectionDate     DateTime?
  disconnectionReason   String?
  disconnectionCategoryId    String?
  disconnectionSubCategoryId String?

  disconnectionCategory    DisconnectionCategory?    @relation(fields: [disconnectionCategoryId], references: [id])
  disconnectionSubCategory DisconnectionSubCategory? @relation(fields: [disconnectionSubCategoryId], references: [id])

  // Attachments: Json array of { url, publicId, originalName }
  attachments           Json?

  // Approval
  approvedById          String?
  approvedAt            DateTime?
  rejectionReason       String?

  // Processing (Accounts/NOC completion)
  processedById         String?
  processedAt           DateTime?
  processNotes          String?

  notes                 String?

  // Docs Review stage
  docsReviewedById        String?
  docsReviewedAt          DateTime?
  docsRejectionReason     String?
  docsReviewedBy          User?       @relation("ServiceOrderDocsReviewed", fields: [docsReviewedById], references: [id])

  // NOC stage
  nocSpeedTestUrl         String?
  nocSpeedTestUploadedAt  DateTime?
  nocProcessedById        String?
  nocProcessedAt          DateTime?
  nocNotes                String?
  nocProcessedBy          User?       @relation("ServiceOrderNocProcessed", fields: [nocProcessedById], references: [id])

  // SAM Activation stage
  activationDate          DateTime?
  activationSetById       String?
  activationSetAt         DateTime?
  activationSetBy         User?       @relation("ServiceOrderActivationSet", fields: [activationSetById], references: [id])

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  customer              Lead                 @relation("ServiceOrderCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  createdBy             User                 @relation("ServiceOrdersCreated", fields: [createdById], references: [id])
  approvedBy            User?                @relation("ServiceOrdersApproved", fields: [approvedById], references: [id])
  processedBy           User?                @relation("ServiceOrdersProcessed", fields: [processedById], references: [id])

  @@index([customerId])
  @@index([createdById])
  @@index([status])
  @@index([orderType, status])
  @@index([docsReviewedById])
  @@index([nocProcessedById])
}

// Disconnection reason categories for service orders
