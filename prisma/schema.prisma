model Complaint {
  id              String               @id @default(uuid())
  complaintNumber String               @unique
  leadId          String
  lead            Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        ComplaintCategory?    @relation(fields: [categoryId], references: [id])
  subCategoryId   String?
  subCategory     ComplaintSubCategory? @relation(fields: [subCategoryId], references: [id])
  status          ComplaintStatus      @default(OPEN)
  priority        ComplaintPriority    @default(MEDIUM)
  description     String
  complaintDate   DateTime             @default(now())
  tatHours        Int
  tatDeadline     DateTime
  notes           String?
  resolutionNotes String?
  resolvedAt      DateTime?
  closedAt        DateTime?
  closedById           String?
  closedBy             User?                @relation("ComplaintsClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  reasonForOutage      String?
  resolution           String?
  resolutionType       String?
  closeRemark          String?
  serviceImpact        Boolean?
  ispImpactFrom        DateTime?
  ispImpactTo          DateTime?
  customerImpactFrom   DateTime?
  customerImpactTo     DateTime?
  reopenCount     Int                  @default(0)
  metadata        Json?
  createdById     String
  createdBy       User                 @relation("ComplaintsCreatedBy", fields: [createdById], references: [id])
  assignments     ComplaintAssignment[]
  attachments     ComplaintAttachment[]
  customerComplaintRequests CustomerComplaintRequest[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([leadId, status])
  @@index([createdById, status])
  @@index([tatDeadline, status])
  @@index([priority, status])
}

model ComplaintAssignment {
  id           String    @id @default(uuid())
  complaintId  String
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation("ComplaintAssignments", fields: [userId], references: [id])
  assignedById String
  assignedBy   User      @relation("ComplaintAssignedBy", fields: [assignedById], references: [id])
  isActive     Boolean   @default(true)
  assignedAt   DateTime  @default(now())

  @@index([userId, isActive])
  @@index([complaintId, isActive])
  @@unique([complaintId, userId])
}

model ComplaintAttachment {
  id           String    @id @default(uuid())
  complaintId  String
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedById String
  uploadedBy   User      @relation("ComplaintAttachmentUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())

  @@index([complaintId])
}

model CustomerComplaintRequest {
  id              String                            @id @default(uuid())
  requestNumber   String                            @unique
  leadId          String
  lead            Lead                              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        ComplaintCategory?                 @relation(fields: [categoryId], references: [id])
  subCategoryId   String?
  subCategory     ComplaintSubCategory?              @relation(fields: [subCategoryId], references: [id])
  description     String
  status          CustomerComplaintRequestStatus    @default(PENDING)
