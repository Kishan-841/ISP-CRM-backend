// Credit Note - reduces the legal demand on an invoice
model CreditNote {
  id                   String              @id @default(uuid())
  creditNoteNumber     String              @unique
  invoiceId            String
  creditNoteDate       DateTime            @default(now())

  // Amounts (must mirror invoice tax structure)
  baseAmount           Float               // Base credit amount
  sgstRate             Float               @default(9)
  cgstRate             Float               @default(9)
  sgstAmount           Float               // SGST credit
  cgstAmount           Float               // CGST credit
  totalGstAmount       Float               // Total GST credit
  totalAmount          Float               // Total credit (base + GST)

  // Reason and status
  reason               CreditNoteReason
  status               CreditNoteStatus    @default(ISSUED)
  remarks              String?

  // If adjusted against another invoice
  adjustedAgainstInvoiceId String?
  adjustedAt           DateTime?

  // If refunded
  refundedAt           DateTime?
  refundReference      String?
  refundMode           String?             // CHEQUE, NEFT, etc.

  // Audit
  createdById          String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  invoice              Invoice             @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id])
  createdBy            User                @relation("CreditNotesCreatedBy", fields: [createdById], references: [id])
  adjustedAgainstInvoice Invoice?          @relation("CreditNoteAdjustments", fields: [adjustedAgainstInvoiceId], references: [id])

  @@index([invoiceId])
  @@index([creditNoteNumber])
  @@index([status])
  @@index([creditNoteDate])
}

// Customer Ledger - Single source of truth for financial transactions
// This is APPEND-ONLY. No updates. No deletes.
model LedgerEntry {
  id                String            @id @default(uuid())
  customerId        String            // leadId - one ledger per customer

  // Entry details
  entryDate         DateTime          // Accounting date (when transaction occurred)
  entryType         LedgerEntryType   // INVOICE, PAYMENT, CREDIT_NOTE, REFUND

  // Reference to source document
  referenceType     String            // "INVOICE" | "PAYMENT" | "CREDIT_NOTE"
  referenceId       String            // UUID of source record
  referenceNumber   String            // Human-readable: Invoice No / Receipt No / CN No

  // Debit/Credit amounts (CRITICAL - follow accounting rules)
  // Debit = Customer owes more | Credit = Customer owes less
  debitAmount       Float             @default(0)
  creditAmount      Float             @default(0)

  // Running balance computed on read, stored for performance
  // runningBalance = previous.runningBalance + debitAmount - creditAmount
  runningBalance    Float             @default(0)

  // Human-readable description for customer statements
  description       String

  // Audit trail
  createdById       String?
  createdAt         DateTime          @default(now())

  // Relations
  customer          Lead              @relation("CustomerLedger", fields: [customerId], references: [id])
  createdBy         User?             @relation("LedgerEntriesCreatedBy", fields: [createdById], references: [id])

  // Indexes for fast retrieval
  @@index([customerId])
  @@index([entryDate])
  @@index([entryType])
  @@index([referenceId])
  @@index([createdAt])
  // Composite index for ledger queries (customer + date order)
  @@index([customerId, entryDate, createdAt])
}

enum LedgerEntryType {
  INVOICE       // Invoice generated - DEBIT
  PAYMENT       // Payment received - CREDIT
  CREDIT_NOTE   // Credit note issued - CREDIT
  REFUND        // Refund processed - DEBIT
}

